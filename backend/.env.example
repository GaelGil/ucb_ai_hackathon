APP_NAME=LangBase API
APP_VERSION=0.1.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3979
SEED_DEMO_DATA=true

BROWSERBASE_API_KEY=
BROWSERBASE_BASE_URL=https://api.browserbase.com

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

PHOENIX_ENABLED=false
PHOENIX_OTEL_ENDPOINT=http://localhost:6006/v1/traces
OTEL_SERVICE_NAME=langbase-backend

NAHUATL_MODEL_ENDPOINT_URL=
NAHUATL_MODEL_NAME=somosnlp-hackathon-2022/t5-small-spanish-nahuatl

HTTP_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=45
# Supabase Postgres connection string (SQLAlchemy / psycopg2 format).
#
# Find it in Supabase: Project Settings -> Database -> Connection string -> URI.
# Use the "Session"/direct connection (port 5432) for Alembic migrations.
# Prefix the scheme with +psycopg2 and append sslmode=require.
#
# Local default:
DATABASE_URL=sqlite:///./langbase.db

# Supabase example:
# DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Set to true to log every SQL statement.
DB_ECHO=false
